# --- App ---
ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
# comma-separated frontend origins allowed to send credentialed requests
CORS_ORIGINS=http://localhost:3000

# --- Database / Redis ---
DATABASE_URL=postgresql+asyncpg://profmatch:profmatch@localhost:5432/profmatch
REDIS_URL=redis://localhost:6379/0

# --- Gemini ---
GEMINI_API_KEY=your-key-here
GEMINI_GEN_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# --- Academic APIs ---
OPENALEX_MAILTO=you@example.com
SEMANTIC_SCHOLAR_API_KEY=
CROSSREF_MAILTO=you@example.com

# --- Credits ---
ANON_FREE_SEARCHES=1
REGISTERED_START_CREDITS=3
REGISTERED_MAX_CREDITS=3
CREDIT_REGEN_INTERVAL_HOURS=48
